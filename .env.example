# --- Database ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me
POSTGRES_DB=groov_db
# Host port the db is exposed on locally (container always listens on 5432)
DB_HOST_PORT=5435

# --- Backend ---
NODE_ENV=production
BACKEND_PORT=3003
# Generate strong secrets: openssl rand -base64 32
ACCESS_TOKEN_SECRET=replace-me-with-a-strong-secret
REFRESH_TOKEN_SECRET=replace-me-with-a-strong-secret
# Comma-separated list of allowed frontend origins (no trailing slash)
CORS_ORIGIN=http://localhost:3000

# --- Frontend ---
FRONTEND_PORT=3000
# Build-time API URL baked into the React bundle. Use "/api" for the
# bundled nginx proxy, or a full URL like "https://api.example.com".
REACT_APP_API_URL=/api
